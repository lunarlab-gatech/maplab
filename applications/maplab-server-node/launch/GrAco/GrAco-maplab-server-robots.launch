<?xml version="1.0"?>

<launch>
	<arg name="user_name" default="$(env USER)" />
	<arg name="dataset_number" default="V1.0"/>

	<arg name="GrAco_playback_speed" default="1.0"/>
	<arg name="GrAco_bags_folder" default="/home/$(arg user_name)/data/Data/GrAco_dataset/$(arg dataset_number)"/>
	<arg name="GrAco_root_map_directory" default="/home/$(arg user_name)/data/Data/GrAco_dataset/$(arg dataset_number)/results/maplab_results"/>
	<!-- ================================== ground-01 ================================================== -->
	<group>
		<arg name="GrAco_robot_name" default="ground1"/>
		<node pkg="rosbag" type="play" name="rosbag_$(arg GrAco_robot_name)" args="$(arg GrAco_bags_folder)/$(arg GrAco_robot_name)/$(arg GrAco_robot_name).bag -q -d 2 -s 0 -r $(arg GrAco_playback_speed)">
			<remap from="/gnss/imu" to="/$(arg GrAco_robot_name)/gnss/imu"/>
			<remap from="/camera_left/image_raw" to="/$(arg GrAco_robot_name)/camera_left/image_raw"/>
			<remap from="/camera_right/image_raw" to="/$(arg GrAco_robot_name)/camera_right/image_raw"/>
			<remap from="/gnss/ground_truth" to="/$(arg GrAco_robot_name)/rovioli/maplab_odom_T_M_I"/>
			<remap from ="/lidar" to="/$(arg GrAco_robot_name)/lidar"/>
		</node> 

		<include file="$(find maplab_server_node)/launch/GrAco/GrAco-maplab-node.launch">
			<arg name="robot_name" default="$(arg GrAco_robot_name)"/>
			<arg name="robot_calib_file" default="GrAco-$(arg GrAco_robot_name).yaml"/>
			<arg name="root_map_directory" default="$(arg GrAco_root_map_directory)"/>
		</include>
	</group>


</launch>
